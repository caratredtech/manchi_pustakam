 "doc_type": "Quotation",
 "docstatus": 0,
 "doctype": "Print Format",
 "font_size": 14,
 "html": "<!DOCTYPE html>\n\n<html>\n<head>\n<meta charset=\"utf-8\">\n\n<style>\n@font-face {\n    font-family: 'NotoTelugu';\n    src: url(\"/files/NotoSansTelugu-Regular.ttf\") format('truetype');\n}\n\nbody {\n    font-family: 'NotoTelugu', Arial, sans-serif;\n    margin: 12px;\n}\n\n* {\n    -webkit-print-color-adjust: exact;\n}\n\n@page {\n    size: A4 landscape;\n    margin: 8mm;\n}\n\n.bill-box {\n    margin: 0 auto;\n    border: 2px solid #000;\n    padding: 8px;\n    width: 100%;\n    box-sizing: border-box;\n    overflow: hidden;\n}\n\n.header {\n    border-bottom: 1px solid #000;\n    padding-bottom: 5px;\n}\n\n.header-row {\n    display: table;\n    width: 100%;\n}\n\n.logo {\n    display: table-cell;\n    width: 70px;\n    vertical-align: middle;\n}\n\n.logo img {\n    width: 55px;\n}\n\n.header-text {\n    display: table-cell;\n    text-align: center;\n}\n\n.header-text h2 {\n    margin: 3px 0;\n}\n\n.header-text p {\n    margin: 2px 0;\n    font-size: 12px;\n}\n\n.bill-details {\n    margin-top: 8px;\n    font-size: 12px;\n    width: 100%;\n}\n\n.bill-details td {\n    vertical-align: top;\n}\n\n.right-section {\n    text-align: right;\n}\n\n.table {\n    width: 100%;\n    margin-top: 8px;\n    border:1px solid black;\n    border-collapse: collapse;\n    table-layout: fixed;\n}\n\n.table th {\n    border: 1px solid #000;\n    text-align: center;\n    font-size: 9px;\n    padding: 4px 3px;\n    white-space: normal;\n    word-break: break-word;\n}\n\n.table td {\n    border: 1px solid #000;\n    padding: 4px 3px;\n    font-size: 9px;\n    white-space: normal;\n    word-break: break-word;\n}\n\n.table th:nth-child(1), .table td:nth-child(1) { width: 4%; text-align:center; }\n.table th:nth-child(2), .table td:nth-child(2) { width: 28%; }\n.table th:nth-child(3), .table td:nth-child(3) { width: 8%; }\n.table th:nth-child(4), .table td:nth-child(4) { width: 10%; }\n.table th:nth-child(5), .table td:nth-child(5) { width: 6%; }\n.table th:nth-child(6), .table td:nth-child(6) { width: 6%; }\n.table th:nth-child(7), .table td:nth-child(7) { width: 8%; text-align:right; }\n.table th:nth-child(8), .table td:nth-child(8) { width: 8%; }\n.table th:nth-child(9), .table td:nth-child(9) { width: 8%; }\n.table th:nth-child(10), .table td:nth-child(10) { width: 6%; text-align:right; }\n.table th:nth-child(11), .table td:nth-child(11) { width: 8%; text-align:right; }\n\n.total-row td {\n    border: none !important;\n    padding: 4px 6px;\n}\n\n.footer {\n    margin-top: 8px;\n    font-size: 11px;\n}\n\n.sign {\n    text-align: right;\n    margin-top: 20px;\n}\n\n@media print {\n    body {\n        zoom: 0.95;\n    }\n}\n</style>\n\n</head>\n\n<body>\n\n<div class=\"bill-box\">\n\n<div class=\"header\">\n    <div class=\"header-row\">\n        <div class=\"logo\">\n            <img src=\"/files/manchipusthakam1logo.png\">\n        </div>\n        <div class=\"header-text\">\n            <p><b>Quotation</b></p>\n            <h2>MANCHI PUSTAKAM</h2>\n            <p>A Trust for Publication and promotion of children's books in Telugu</p>\n            <p>12-13-439, St. No. 1, TARNAKA</p>\n            <p>Secunderabad - 500 017. Mobile: 8125923781</p>\n            <p>www.manchipustakam.in</p>\n        </div>\n    </div>\n</div>\n\n<table class=\"bill-details\">\n{% set mobile = frappe.db.get_value(\"Customer\", {\"name\": doc.party_name}, [\"custom_mobile_number\"]) %}\n<tr>\n    <td>\n        M/s: <u>{{ doc.customer_name }}</u><br>\n        Mobile: {{ mobile or \"\"}}\n    </td>\n    <td class=\"right-section\">\n        <b>Quotation No:</b> {{ doc.name }}<br>\n        <b>Date:</b> {{ frappe.utils.formatdate(doc.transaction_date, \"dd-mm-yyyy\") }}\n    </td>\n</tr>\n</table>\n\n<table class=\"table\">\n<tr>\n    <th>S.No</th>\n    <th>Title</th>\n    <th>Author</th>\n    <th>Publisher</th>\n    <th>Year</th>\n    <th>Pages</th>\n    <th>Price</th>\n    <th>Subject</th>\n    <th>Age Group</th>\n    <th>No. Of Copies</th>\n    <th>Amount</th>\n</tr>\n\n{% for i in doc.items %}\n{% set item_doc = frappe.db.get_all(\n\"Item\",\n{\"name\": i.item_code},\n[\"brand\",\"item_group\",\"custom_year_of_publication\",\"custom_author_\",\"custom_age_group\",\"custom_pages\"]\n) %}\n{% set item = item_doc[0] if item_doc else {} %}\n\n<tr>\n    <td>{{ i.idx }}</td>\n    <td>{{ i.item_name or \"\" }}</td>\n    <td>{{ item.custom_author_ or \"\" }}</td>\n    <td>{{ item.brand or \"\" }}</td>\n    <td>{{ item.custom_year_of_publication or \"\" }}</td>\n    <td>{{ item.custom_pages or \"\" }}</td>\n    <td>{{ \"{:,.2f}\".format(i.rate or 0) }}</td>\n    <td>{{ item.item_group or \"\" }}</td>\n    <td>{{ item.custom_age_group or \"\" }}</td>\n    <td>{{ i.qty or 0 }}</td>\n    <td>{{ \"{:,.2f}\".format(i.amount or 0) }}</td>\n</tr>\n{% endfor %}\n\n<tr class=\"total-row\">\n    <td colspan=\"7\"></td>\n\n    <td colspan=\"4\">\n        <table style=\"width:100%; font-size:9px; border-collapse:collapse;\">\n            <tr>\n                <td style=\"border:none; white-space:nowrap;\"><b>Total</b></td>\n                <td style=\"text-align:right; border:none; white-space:nowrap;\">\n                    <b>{{ \"{:,.2f}\".format(doc.total or 0) }}</b>\n                </td>\n            </tr>\n            <tr>\n                <td style=\"border:none; white-space:nowrap;\"><b>Discount</b></td>\n                <td style=\"text-align:right; border:none; white-space:nowrap;\">\n                    <b>{{ \"{:,.2f}\".format(doc.discount_amount or 0) }}</b>\n                </td>\n            </tr>\n\n            {% if doc.custom_other_charges and doc.custom_include %}\n            <tr>\n                <td style=\"border:none; white-space:nowrap;\"><b>Other Charges</b></td>\n                <td style=\"text-align:right; border:none; white-space:nowrap;\">\n                    <b>{{ \"{:,.2f}\".format(doc.custom_other_charges or 0) }}</b>\n                </td>\n            </tr>\n            {% endif %}\n\n            <tr>\n                <td style=\"border-top:1px solid #000; white-space:nowrap;\"><b>Net Amount</b></td>\n                <td style=\"text-align:right; border-top:1px solid #000; white-space:nowrap;\">\n                    <b>{{ \"{:,.2f}\".format(doc.rounded_total or 0) }}</b>\n                </td>\n            </tr>\n        </table>\n    </td>\n</tr>\n\n</table>\n\n<div class=\"footer\">\n    <p>\n        Rupees in words <u>{{ doc.in_words }}</u>\n    </p>\n\n<div class=\"sign\">\n\n    <p style=\"text-align:left;font-size: 10px;\">\n        This Is System Generated Quotation Signature Is Not Required\n    </p>\n\n    <p>For MANCHI PUSTAKAM</p>\n    <br><br>\n    <p>Authorised Signatory</p>\n</div>\n\n</div>\n\n</div>\n\n</body>\n</html>",
