 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n\n<style>\n@font-face {\n    font-family: 'NotoTelugu';\n    src: url(\"/files/NotoSansTelugu-Regular.ttf\") format('truetype');\n}\n\nbody {\n    font-family: 'NotoTelugu', Arial, sans-serif;\n}\n\n* {\n    -webkit-print-color-adjust: exact;\n}\n\n.bill-box {\n    margin: auto;\n    border: 2px solid #000;\n    padding: 10px;\n}\n\n.header {\n    border-bottom: 1px solid #000;\n    padding-bottom: 5px;\n}\n\n.header-row {\n    display: table;\n    width: 100%;\n}\n\n.logo {\n    display: table-cell;\n    width: 80px;\n    vertical-align: middle;\n}\n\n.logo img {\n    width: 60px;\n}\n\n.header-text {\n    display: table-cell;\n    text-align: center;\n}\n\n.header-text h2 {\n    margin: 3px 0;\n}\n\n.header-text p {\n    margin: 2px 0;\n    font-size: 13px;\n}\n\n.bill-details {\n    margin-top: 10px;\n    font-size: 14px;\n    width: 100%;\n}\n\n.bill-details td {\n    vertical-align: top;\n}\n\n.right-section {\n    text-align: right;\n}\n\n.table {\n    width: 100%;\n    /*border-collapse: collapse;*/\n    margin-top: 10px;\n    table-layout: fixed;\n    border:1px solid black;\n}\n\n.table th, .table td {\n    border: 1px solid #000;\n    padding: 6px;\n    font-size: 13px;\n}\n\n.table th {\n    text-align: center;\n}\n\n.table td:nth-child(1) { text-align: center; }\n.table td:nth-child(2) { text-align: left; }\n.table td:nth-child(3),\n.table td:nth-child(4),\n.table td:nth-child(5) { text-align: right; }\n\n.total-row td {\n    border: 1px solid #000 !important;\n    font-weight: bold;\n}\n\n.footer {\n    margin-top: 10px;\n    font-size: 13px;\n}\n\n.sign {\n    text-align: right;\n    margin-top: 30px;\n}\n\n</style>\n</head>\n\n<body>\n\n<div class=\"bill-box\">\n\n    <div class=\"header\">\n        <div class=\"header-row\">\n            <div class=\"logo\">\n                <img src=\"/files/manchipusthakam1logo.png\">\n            </div>\n            <div class=\"header-text\">\n                <p><b>Tax Invoice</b></p>\n                <h2>MANCHI PUSTAKAM</h2>\n                <p>A Trust for Publication and promotion of children's books in Telugu</p>\n                <p>12-13-439, St. No. 1, TARNAKA</p>\n                <p>Secunderabad - 500 017. Mobile: 8125923781</p>\n                <p>www.manchipustakam.in</p>\n            </div>\n        </div>\n    </div>\n\n    <table class=\"bill-details\">\n        <tr>\n            <td>\n                M/s: <u>{{ doc.customer }}</u><br>\n                Mobile: {{ doc.custom_mobile_number or \"\"}}\n            </td>\n            <td class=\"right-section\">\n                <b>Bill No:</b> {{ doc.name }}<br>\n                <b>Date:</b> {{ frappe.utils.formatdate(doc.posting_date, \"dd-mm-yyyy\") }}<br>\n                <b>Payment Method:</b> {{ doc.custom_mode_of_payment or \"\" }}\n            </td>\n        </tr>\n    </table>\n\n    <table class=\"table\">\n        <tr>\n            <th style=\"width:7%\">S.No.</th>\n            <th style=\"width:45%\">PARTICULARS</th>\n            <th style=\"width:10%\">Qty.</th>\n            <th style=\"width:18%\">Rate</th>\n            <th style=\"width:20%\">Amount</th>\n        </tr>\n\n        {% for i in doc.items %}\n        <tr>\n            <td>{{ i.idx }}</td>\n            <td>{{ i.item_name or \"\" }}</td>\n            <td>{{ i.qty or \"\" }}</td>\n            <td>{{ \"{:,.2f}\".format(i.rate or 0) }}</td>\n            <td>{{ \"{:,.2f}\".format(i.amount or 0) }}</td>\n        </tr>\n        {% endfor %}\n\n       <tr class=\"total-row\">\n            <td colspan=\"3\" style=\"border:none;\">&nbsp;</td>\n            <!--<td style=\"border:none;\">&nbsp;</td>-->\n            <!--<td style=\"border:none;\">&nbsp;</td>-->\n            <td style=\"text-align:right; border-left:1px solid #fff; white-space:nowrap;\">\n    <b>\n        Total<br>\n        Discount<br>\n        {% if doc.custom_other_charges %}\n            Other Charges<br>\n        {% endif %}\n        Net Amount\n    </b>\n</td>\n            <td style=\"text-align:right; border:1px solid #000;\">\n                <b>{{ \"{:,.2f}\".format(doc.total or 0) }}</b><br><b>{{ \"{:,.2f}\".format(doc.discount_amount or 0) }}</b><br>{% if doc.custom_other_charges %}\n            <b>{{doc.custom_other_charges }}</b><br>\n        {% endif %}\n        <b>{{ \"{:,.2f}\".format(doc.rounded_total or 0) }}</b>\n            </td>\n        </tr>\n    </table>\n\n    <div class=\"footer\">\n        <p>\n            Rupees in words <u>{{ doc.in_words }}</u>\n        </p>\n\n        <div class=\"sign\">\n            <p style=\"text-align:left;font-size: 7px;\">\n                PRINTED BOOKS @ 0% GST HSN 4901\n            </p>\n            <p style=\"text-align:left;font-size: 10px;\">\n                This Is System Generated Invoice Signature Is Not Requird\n            </p>\n            <p style=\"text-align:left;font-size: 10px;\">\n                Books Can't Be Returned or Exchanged\n            </p>\n            <p>For MANCHI PUSTAKAM</p>\n            <br><br>\n            <p>Authorised Signatory</p>\n        </div>\n    </div>\n\n</div>\n\n</body>\n</html>",
